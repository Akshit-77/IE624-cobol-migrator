# LLM Provider Selection
# Options: openai, anthropic, google, xai
LLM_PROVIDER=openai

# API Keys (add the key for your selected provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Optional: Override default models per task
# OpenAI (default: gpt-4o for main tasks, gpt-4o-mini for lighter tasks)
# OPENAI_TRANSLATE_MODEL=gpt-4o
# OPENAI_JUDGE_MODEL=gpt-4o
# OPENAI_PLANNER_MODEL=gpt-4o
# OPENAI_ANALYZE_MODEL=gpt-4o-mini
# OPENAI_REFLECT_MODEL=gpt-4o-mini

# Anthropic (default: claude-sonnet-4 for main, claude-haiku-4 for lighter)
# ANTHROPIC_TRANSLATE_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-20250514

# Google (default: gemini-2.0-flash)
# GOOGLE_TRANSLATE_MODEL=gemini-2.0-flash

# xAI/Grok (default: grok-2)
# XAI_TRANSLATE_MODEL=grok-2

# Frontend API base URL (optional, defaults to http://localhost:8000)
# VITE_API_BASE=http://localhost:8000
