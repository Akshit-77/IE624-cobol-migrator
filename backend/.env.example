# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Options: openai, anthropic, google, xai
# Change this to switch between providers
LLM_PROVIDER=openai

# =============================================================================
# API Keys (only the key for your selected provider is required)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-api-key
XAI_API_KEY=your-xai-key

# =============================================================================
# OpenAI Models (used when LLM_PROVIDER=openai)
# Available: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo, o1, o1-mini
# =============================================================================
OPENAI_TRANSLATE_MODEL=gpt-4o
OPENAI_JUDGE_MODEL=gpt-4o
OPENAI_PLANNER_MODEL=gpt-4o
OPENAI_ANALYZE_MODEL=gpt-4o-mini
OPENAI_REFLECT_MODEL=gpt-4o-mini

# =============================================================================
# Anthropic Models (used when LLM_PROVIDER=anthropic)
# Available: claude-sonnet-4-20250514, claude-haiku-4-20250514, claude-opus-4-20250514
# =============================================================================
ANTHROPIC_TRANSLATE_MODEL=claude-sonnet-4-20250514
ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-20250514
ANTHROPIC_PLANNER_MODEL=claude-sonnet-4-20250514
ANTHROPIC_ANALYZE_MODEL=claude-haiku-4-20250514
ANTHROPIC_REFLECT_MODEL=claude-haiku-4-20250514

# =============================================================================
# Google Gemini Models (used when LLM_PROVIDER=google)
# Available: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
# =============================================================================
GOOGLE_TRANSLATE_MODEL=gemini-2.0-flash
GOOGLE_JUDGE_MODEL=gemini-2.0-flash
GOOGLE_PLANNER_MODEL=gemini-2.0-flash
GOOGLE_ANALYZE_MODEL=gemini-2.0-flash
GOOGLE_REFLECT_MODEL=gemini-2.0-flash

# =============================================================================
# xAI Grok Models (used when LLM_PROVIDER=xai)
# Available: grok-2, grok-2-mini
# =============================================================================
XAI_TRANSLATE_MODEL=grok-2
XAI_JUDGE_MODEL=grok-2
XAI_PLANNER_MODEL=grok-2
XAI_ANALYZE_MODEL=grok-2
XAI_REFLECT_MODEL=grok-2

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_PATH=data/migrations.db

# =============================================================================
# CORS Origins (for frontend)
# =============================================================================
# CORS_ORIGINS=["http://localhost:5173"]
